; 架构护栏：把根目录 ARCHITECTURE.md 的依赖规则变成可执行门禁。
; 跑：cd backend && $env:PYTHONUTF8=1; .venv/Scripts/lint-imports
[importlinter]
root_package = app

[importlinter:contract:services-not-depend-on-routers]
name = services 层不得依赖 routers 层（分层：路由薄、业务下沉，service 可独立单测）
type = forbidden
source_modules =
    app.services
forbidden_modules =
    app.routers

[importlinter:contract:background-run-stack-layers]
name = 后台运行栈方向：队列依赖 agent_runner，agent_runner 依赖底座(thread_admission/agent_contracts)，底座不得反向依赖
type = layers
layers =
    app.services.chat_agent_queue
    app.services.agent_runner
    app.services.thread_admission | app.services.agent_contracts

[importlinter:contract:rag-stack-layers]
name = RAG 栈方向：编排依赖检索与存储，向量后端不得反向依赖
type = layers
layers =
    app.services.node_index | app.services.rag_store
    app.services.node_store | app.services.rag_retrieval | app.services.reranker
    app.services.rag_backend

[importlinter:contract:workflow-build-stack-layers]
name = 搭建栈方向：编排依赖搭建回合与图规则，底层不得反向依赖
type = layers
layers =
    app.services.workflow_build_tasks
    app.services.workflow_builder
    app.services.workflow_build_turn | app.services.workflow_graph_rules | app.services.workflow_merge
    app.services.node_candidates
    app.services.node_index
    app.services.rag_middleware

[importlinter:contract:chat-stream-protocol-layers]
name = 对话流协议方向：SSE Adapter 依赖 wire 协议，协议不得反向依赖
type = layers
layers =
    app.services.sse
    app.services.chat_stream_protocol
